{
  "manifest_version": 3,
  "name": "No Thanks, ChatGPT",
  "version": "3.0.0",
  "description": "Blocks ChatGPT popups and lets you locally export loaded conversations as Markdown, JSON, HTML, or TXT.",
  "author": "DeepakNess",
  "action": {
    "default_popup": "popup.html",
    "default_title": "No Thanks, ChatGPT"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "*://chat.openai.com/*",
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "*://chat.openai.com/*",
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*"
      ],
      "js": ["exporter.js"],
      "run_at": "document_idle"
    }
  ]
}
